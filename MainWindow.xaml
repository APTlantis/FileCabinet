<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FileCabinet - Personal Vault &amp; Artifact Manager"
        Width="1680"
        Height="1040"
        MinWidth="1180"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="#07111C"
        Foreground="#E7EEF8">
    <Window.Resources>
        <Color x:Key="WindowBg">#07111C</Color>
        <Color x:Key="PanelBg">#0B1724</Color>
        <Color x:Key="PanelAltBg">#0F1C2A</Color>
        <Color x:Key="CardBg">#101D2B</Color>
        <Color x:Key="CardHiBg">#142337</Color>
        <Color x:Key="BorderDim">#223246</Color>
        <Color x:Key="BorderStrong">#334860</Color>
        <Color x:Key="Accent">#4DA3FF</Color>
        <Color x:Key="AccentDeep">#1E63B6</Color>
        <Color x:Key="AccentSoft">#173A61</Color>
        <Color x:Key="Green">#55D680</Color>
        <Color x:Key="Amber">#F5A623</Color>
        <Color x:Key="Red">#F24F5F</Color>
        <Color x:Key="Purple">#9566FF</Color>
        <Color x:Key="PrimaryText">#E7EEF8</Color>
        <Color x:Key="SecondaryText">#AEBBCD</Color>
        <Color x:Key="MutedText">#728198</Color>

        <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource WindowBg}" />
        <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource PanelBg}" />
        <SolidColorBrush x:Key="PanelAltBgBrush" Color="{StaticResource PanelAltBg}" />
        <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource CardBg}" />
        <SolidColorBrush x:Key="CardHiBgBrush" Color="{StaticResource CardHiBg}" />
        <SolidColorBrush x:Key="BorderDimBrush" Color="{StaticResource BorderDim}" />
        <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrong}" />
        <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Accent}" />
        <SolidColorBrush x:Key="AccentDeepBrush" Color="{StaticResource AccentDeep}" />
        <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoft}" />
        <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Green}" />
        <SolidColorBrush x:Key="AmberBrush" Color="{StaticResource Amber}" />
        <SolidColorBrush x:Key="RedBrush" Color="{StaticResource Red}" />
        <SolidColorBrush x:Key="PurpleBrush" Color="{StaticResource Purple}" />
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource PrimaryText}" />
        <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource SecondaryText}" />
        <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource MutedText}" />

        <LinearGradientBrush x:Key="ShellGradientBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A1521" Offset="0" />
            <GradientStop Color="#0B1827" Offset="0.55" />
            <GradientStop Color="#07111C" Offset="1" />
        </LinearGradientBrush>

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#18283A" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="Background" Value="#22364D" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="#122133" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#192B40" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavRow" TargetType="Border">
            <Setter Property="Height" Value="30" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Background" Value="Transparent" />
        </Style>

        <Style x:Key="NavRowSelected" TargetType="Border" BasedOn="{StaticResource NavRow}">
            <Setter Property="Background" Value="#1B4778" />
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="#172538" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="DataCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="DataHeader" TargetType="TextBlock" BasedOn="{StaticResource DataCell}">
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource ShellGradientBrush}" BorderBrush="#162437" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="#050B12" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" FontSize="15" />
                    <TextBlock Text="FileCabinet - Personal Vault &amp; Artifact Manager"
                               Margin="9,0,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="MinimizeButton" Content="&#xE921;" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" />
                    <Button x:Name="MaximizeButton" Content="&#xE922;" Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" />
                    <Button x:Name="CloseButton" Content="&#xE8BB;" Style="{StaticResource ChromeButton}" Click="CloseButton_Click">
                        <Button.Resources>
                            <Style TargetType="Border" />
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="235" MinWidth="210" />
                    <ColumnDefinition Width="*" MinWidth="720" />
                    <ColumnDefinition Width="330" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#091522" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <TextBlock Text="VAULTS" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                            <TextBlock Text="+" Foreground="{StaticResource SecondaryTextBrush}" FontSize="20" HorizontalAlignment="Right" />
                        </Grid>

                        <StackPanel Grid.Row="1" Margin="0,0,0,18">
                            <Border Style="{StaticResource NavRowSelected}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                    <TextBlock Grid.Column="1" Text="MainVault (H:)" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource NavRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                                    <TextBlock Grid.Column="1" Text="ArchiveVault (D:)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource NavRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" />
                                    <TextBlock Grid.Column="1" Text="ColdStorage (E:)" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                            <Border Style="{StaticResource NavRow}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="24" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="+" Foreground="{StaticResource SecondaryTextBrush}" FontSize="18" VerticalAlignment="Center" />
                                    <TextBlock Grid.Column="1" Text="Add Vault" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                </Grid>
                            </Border>
                        </StackPanel>

                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,1,0,1" Padding="0,13">
                            <StackPanel>
                                <TextBlock Text="NAVIGATION" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                <Border Style="{StaticResource NavRowSelected}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE80F;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Grid.Column="1" Text="Dashboard" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource NavRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE8A5;" Style="{StaticResource IconText}" />
                                        <TextBlock Grid.Column="1" Text="All Items" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource NavRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE823;" Style="{StaticResource IconText}" />
                                        <TextBlock Grid.Column="1" Text="Recent" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource NavRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE715;" Style="{StaticResource IconText}" />
                                        <TextBlock Grid.Column="1" Text="Inbox" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                        <Border Grid.Column="2" Background="{StaticResource AccentBrush}" CornerRadius="9" Padding="8,2">
                                            <TextBlock Text="12" FontSize="11" Foreground="White" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource NavRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE734;" Style="{StaticResource IconText}" />
                                        <TextBlock Grid.Column="1" Text="Starred" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource NavRow}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE783;" Style="{StaticResource IconText}" Foreground="{StaticResource RedBrush}" />
                                        <TextBlock Grid.Column="1" Text="Quarantine" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                        <Border Grid.Column="2" Background="{StaticResource RedBrush}" CornerRadius="9" Padding="8,2">
                                            <TextBlock Text="2" FontSize="11" Foreground="White" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,13,0,13">
                            <StackPanel>
                                <TextBlock Text="CATEGORIES" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                <Grid Margin="0,0,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Documents" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="1,245" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Images" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="1,102" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Audio" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="152" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Video" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="98" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Software / Installers" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="374" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="ISOs / Disk Images" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="41" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Archives" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="268" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Keys / Security" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="33" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,2">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Manifests / Config" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="213" Style="{StaticResource DataCell}" />
                                </Grid>
                                <Grid Margin="0,7,0,20">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBlock Text="Other" Style="{StaticResource DataCell}" />
                                    <TextBlock Grid.Column="1" Text="1,108" Style="{StaticResource DataCell}" />
                                </Grid>

                                <TextBlock Text="TAGS (cloud)" Style="{StaticResource SmallLabel}" Margin="0,0,0,10" />
                                <WrapPanel>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="ubuntu" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="iso" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="pgp" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="installer" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="toml" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="backup" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="security" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                    <Border Style="{StaticResource Chip}"><TextBlock Text="archive" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" /></Border>
                                </WrapPanel>
                                <Border Background="#101C2B" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Height="32" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="9,0" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE721;" Style="{StaticResource IconText}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBlock Text="Search tags..." Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,12,0,0">
                            <TextBlock Text="&#xE713;" Style="{StaticResource IconText}" />
                            <TextBlock Text="Settings" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" Margin="9,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="MainVault (H:)" Foreground="{StaticResource PrimaryTextBrush}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="  •  " Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                            <TextBlock Text="4,921 items" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" />
                            <TextBlock Text="  •  " Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                            <TextBlock Text="247.8 GB used of 1.81 TB" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Width="300" Height="34" Background="#101C2B" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal" Margin="11,0" VerticalAlignment="Center">
                                    <TextBlock Text="&#xE721;" Style="{StaticResource IconText}" FontSize="12" Foreground="{StaticResource SecondaryTextBrush}" />
                                    <TextBlock Text="Search vault..." Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="9,0,0,0" />
                                </StackPanel>
                            </Border>
                            <Button Content="&#xE71C;" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" />
                            <Button Content="&#xE80A;" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                            <Button Content="&#xE8A5;" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                            <Button Content="&#xE712;" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,0,0,14">
                        <Border Style="{StaticResource PanelBorder}" Height="88" Margin="0,0,10,0">
                            <Grid Margin="18,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Ellipse Width="44" Height="44" Fill="#153C67" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="4,921" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Total Items" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource PanelBorder}" Height="88" Margin="0,0,10,0">
                            <Grid Margin="18,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Ellipse Width="44" Height="44" Fill="#2C2356" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE74E;" Style="{StaticResource IconText}" Foreground="{StaticResource PurpleBrush}" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="247.8 GB" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Vault Size" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource PanelBorder}" Height="88" Margin="0,0,10,0">
                            <Grid Margin="18,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                <Ellipse Width="44" Height="44" Fill="#183C2B" VerticalAlignment="Center" />
                                <TextBlock Text="&#xE930;" Style="{StaticResource IconText}" Foreground="{StaticResource GreenBrush}" FontSize="19" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="4,712" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" />
                                    <TextBlock Text="Indexed" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border Style="{StaticResource PanelBorder}" Height="88" Margin="0,0,10,0">
                            <Grid Margin="18,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="56" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
