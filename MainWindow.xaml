<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FileCabinet"
        Title="FileCabinet - Personal Vault &amp; Artifact Manager"
        Width="1680"
        Height="1040"
        MinWidth="1180"
        MinHeight="720"
        Icon="Assets/FileCabinet.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource PrimaryTextBrush}">
    <Window.Resources>
        <local:BindingProxy x:Key="VmProxy" Data="{Binding}" />

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DataCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource NeonInk.SoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelTabButton" TargetType="RadioButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="82" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Margin" Value="0,0,6,0" />
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.PipelineBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource NeonInk.FeaturedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavCommandButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="5" Padding="4,3">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NeonInk.SoftBrush}" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="EditorComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource EditorComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="10" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.SoftBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>

                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CaretBrush="{StaticResource PrimaryTextBrush}"
                                     FontSize="{TemplateBinding FontSize}"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center" />

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource CardAltBrush}"
                                        BorderBrush="{StaticResource BorderDimBrush}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource NeonInk.BaseBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource NeonInk.BaseBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource NeonInk.BaseBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource ShellGradientBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource NeonInk.VoidBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" FontSize="15" />
                    <TextBlock Text="FileCabinet - Personal Vault &amp; Artifact Manager"
                               Margin="9,0,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Menu Background="Transparent"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          Margin="18,0,0,0"
                          VerticalAlignment="Center">
                        <MenuItem Header="Settings" Command="{Binding ShowSettingsCommand}" />
                        <MenuItem Header="Help">
                            <MenuItem Header="User Guide" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="README.md" />
                            <MenuItem Header="Deliberate Retention Tradeoff" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — The Deliberate Retention Tradeoff.md" />
                            <MenuItem Header="Trust and Verification Model" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Trust and Verification Model.md" />
                            <MenuItem Header="Why SHA-256 and BLAKE3" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Why SHA-256 and BLAKE3.md" />
                            <MenuItem Header="Repair and Recovery Guide" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Repair and Recovery Guide.md" />
                            <MenuItem Header="Deterministic Vault Roadmap" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Deterministic Vault Roadmap.md" />
                            <Separator />
                            <MenuItem Header="Open Docs Folder" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenDocsFolderCommand}" />
                            <MenuItem Header="About FileCabinet" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding ShowAboutCommand}" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="&#xE921;" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" />
                    <Button Content="&#xE922;" Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" />
                    <Button Content="&#xE8BB;" Style="{StaticResource ChromeButton}" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="235" MinWidth="210" />
                    <ColumnDefinition Width="*" MinWidth="720" />
                    <ColumnDefinition Width="330" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="VAULTS" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="&#xE8B7;" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Width="30" Height="26" Padding="0" Click="ChooseVaultButton_Click" ToolTip="Set selected vault folder" />
                                <Button Content="&#xE738;" Command="{Binding RemoveCurrentVaultCommand}" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Width="30" Height="26" Padding="0" Margin="6,0,0,0" ToolTip="Remove selected vault from list" />
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Vaults}"
                                 SelectedItem="{Binding CurrentVault}"
                                 Style="{StaticResource NavListBox}"
                                 ItemContainerStyle="{StaticResource NavListBoxItem}"
                                 Margin="0,0,0,14">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,1,0,1" Padding="0,13">
                            <StackPanel>
                                <TextBlock Text="NAVIGATION" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                <Button Command="{Binding ClearFiltersCommand}" Style="{StaticResource NavCommandButton}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE80F;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Dashboard" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Content="All Items" Command="{Binding ShowAllItemsCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,7,0,0" />
                                <Button Content="Recent" Command="{Binding ShowRecentCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Grid Margin="0,10,0,0">
                                    <Button Content="Inbox" Command="{Binding ShowRecentCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" CornerRadius="9" Padding="8,2">
                                        <TextBlock Text="{Binding InboxCountText}" FontSize="11" Foreground="{StaticResource NeonInk.InverseTextBrush}" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Button Content="Starred" Command="{Binding ShowStarredCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource NeonInk.ImportantBrush}" CornerRadius="9" Padding="8,2">
                                        <TextBlock Text="{Binding StarredCountText}" FontSize="11" Foreground="{StaticResource NeonInk.InverseTextBrush}" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Button Content="Quarantine" Command="{Binding ShowQuarantineCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource NeonInk.CriticalBrush}" CornerRadius="9" Padding="8,2">
                                        <TextBlock Text="{Binding QuarantineCountText}" FontSize="11" Foreground="{StaticResource NeonInk.InverseTextBrush}" />
                                    </Border>
                                </Grid>
                                <Button Content="Unverified" Command="{Binding ShowUnverifiedCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,10,0,0" />
                                <Button Content="Missing Preview" Command="{Binding ShowMissingPreviewCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Repair Needed" Command="{Binding ShowRepairNeededCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Duplicate Candidates" Command="{Binding ShowDuplicateCandidatesCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Same Source Batch" Command="{Binding ShowSameSourceBatchCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Large Artifacts" Command="{Binding ShowLargeArtifactsCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,13,0,13">
                            <StackPanel>
                                <TextBlock Text="CATEGORIES" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding Categories}"
                                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                         Style="{StaticResource NavListBox}"
                                         ItemContainerStyle="{StaticResource FilterListBoxItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource DataCell}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Count}" Style="{StaticResource DataCell}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="TAGS" Style="{StaticResource SmallLabel}" Margin="0,12,0,10" />
                                <ListBox ItemsSource="{Binding FilteredTags}"
                                         SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                         Style="{StaticResource NavListBox}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Root" Background="Transparent" CornerRadius="5">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource Chip}">
                                                <TextBlock Text="{Binding}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Background="{StaticResource NeonInk.PanelBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Height="32" Margin="0,8,0,0">
                                    <Grid Margin="9,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE721;" Style="{StaticResource IconText}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding TagSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                 FontSize="12"
                                                 Padding="0"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Filter visible tags" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="&#xE713;" Command="{Binding ShowSettingsCommand}" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Width="30" Height="28" Padding="0" ToolTip="Settings summary" />
                            <Button Content="Settings" Command="{Binding ShowSettingsCommand}" Style="{StaticResource ToolButton}" Height="28" Margin="9,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentVaultTitle}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="  •  " Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding CurrentVaultSummary}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Width="300" Height="34" Background="{StaticResource NeonInk.PanelBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Margin="0,0,8,0">
                                <Grid Margin="11,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE721;" Style="{StaticResource IconText}" FontSize="12" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             FontSize="12"
                                             Padding="0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Search vault by name, type, category, path, notes, hash, or tag" />
                                </Grid>
                            </Border>
                            <Button Content="&#xE72C;" Command="{Binding RefreshCommand}" ToolTip="Refresh vault" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" />
                            <Button Content="&#xE8FD;" Command="{Binding SortByNameCommand}" ToolTip="Sort by name" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                            <Button Content="&#xE787;" Command="{Binding SortByDateCommand}" ToolTip="Sort by date" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                            <Button Content="&#xE713;" Command="{Binding ShowSettingsCommand}" ToolTip="Settings summary" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Stats}" Margin="0,0,0,14">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Height="88" Margin="0,0,10,0">
                                    <Grid Margin="18,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="44" Height="44" Fill="{Binding IconBackground}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Icon}" Style="{StaticResource IconText}" Foreground="{Binding IconBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Value}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="390" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" MinWidth="500" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.95*" MinWidth="360" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="230" MinHeight="230" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Margin="12"
                                        BorderBrush="{StaticResource NeonInk.ProcessBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="6"
                                        Background="{StaticResource NeonInk.SoftBrush}"
                                        AllowDrop="True"
                                        Drop="DropZone_Drop"
                                        MouseLeftButtonUp="DropZone_MouseLeftButtonUp">
                                    <Grid Margin="18,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="DROP ZONE - INGEST FILES" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />

                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NeonInk.PipelineBrush}" FontSize="52" HorizontalAlignment="Center" />
                                            <TextBlock Text="Drag &amp; drop files or folders here" Foreground="{StaticResource PrimaryTextBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                            <TextBlock Text="or click to browse" Foreground="{StaticResource NeonInk.FeaturedBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,7,0,0" />
                                            <Border Background="{StaticResource NeonInk.PipelineBrush}" BorderBrush="{StaticResource NeonInk.FeaturedBrush}" BorderThickness="1" CornerRadius="5" Padding="10,4" HorizontalAlignment="Center" Margin="0,8,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="INTAKE MODE:" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding IngestModeText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding IngestStatus}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Center" />
                                            <ProgressBar Width="360"
                                                         Height="8"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding IngestProgress}"
                                                         Visibility="{Binding IsIngesting, Converter={StaticResource BoolToVisibility}}"
                                                         Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding IngestDetail}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="520" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Margin="18,2,18,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Ingest Options" Style="{StaticResource SectionTitle}" Margin="0,0,0,9" />
                                        <WrapPanel>
                                            <Button Command="{Binding ToggleIngestModeCommand}" Style="{StaticResource ToolButton}" MinHeight="52" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding IngestModeText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding DuplicatePolicyText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                </StackPanel>
                                            </Button>
                                            <Border Background="{StaticResource NeonInk.PanelBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Padding="12,8" Margin="0,0,8,8">
                                                <TextBlock Text="{Binding IngestModeDetail}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" TextWrapping="Wrap" Width="180" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BorderDimBrush}" Margin="10,0" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Auto-Process" Style="{StaticResource SectionTitle}" Margin="0,0,0,9" />
                                        <CheckBox Content="Extract searchable text" IsChecked="True" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,7" />
                                        <CheckBox Content="Verify hashes" IsChecked="True" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,7" />
                                        <CheckBox Content="Create thumbnails / previews" IsChecked="True" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,7" />
                                        <CheckBox Content="Record original source path" IsChecked="True" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,10" />
                                        <Button Content="More options..." Command="{Binding ShowSettingsCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelBorder}">
                            <StackPanel Margin="16">
                                <TextBlock Text="RECENT ACTIVITY" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,18" />
                                <ItemsControl ItemsSource="{Binding Activities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="22" Height="22" CornerRadius="11" Background="{Binding IconBackground}">
                                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="{Binding IconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding ActionText}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" />
                                                    <TextBlock Text="{Binding DetailText}" Style="{StaticResource SmallLabel}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="View all activity..." Foreground="{StaticResource AccentBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource PanelBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="16,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FilterTitle}" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                        <Button Content="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource ToolButton}" Height="26" Margin="12,0,0,0" Padding="10,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="&#xE8FD;" Command="{Binding SortByNameCommand}" ToolTip="Sort by name" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" />
                                        <Button Content="&#xE787;" Command="{Binding SortByDateCommand}" ToolTip="Sort by modified date" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                                        <Button Content="{Binding ColumnPresetText}" Command="{Binding CycleColumnPresetCommand}" ToolTip="Cycle visible columns" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                                        <Button Content="{Binding DensityText}" Command="{Binding ToggleDensityCommand}" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                                        <Button Content="Repair  &#xE90F;" Command="{Binding RepairCatalogCommand}" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                                        <Button Content="Rescan  &#xE117;" Command="{Binding RescanVaultCommand}" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Grid>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding FilteredArtifacts}"
                                          SelectedItem="{Binding SelectedArtifact, Mode=TwoWay}"
                                          RowHeight="{Binding ArtifactRowHeight}"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name" Width="2.2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="20" Height="20" CornerRadius="10" Background="{StaticResource NeonInk.StructureBrush}" Margin="0,0,12,0">
                                                            <TextBlock Text="&#xEA86;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NeonInk.InverseTextBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Name}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*" Visibility="{Binding Data.ShowTypeColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.45*" Visibility="{Binding Data.ShowCategoryColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" Width="0.9*" Visibility="{Binding Data.ShowSizeColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTextColumn Header="Date Modified" Binding="{Binding DateModified}" Width="1.15*" Visibility="{Binding Data.ShowDateColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTemplateColumn Header="Tags" Width="1.9*" Visibility="{Binding Data.ShowTagsColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock Text="{Binding TagsText}" Style="{StaticResource DataCell}" Margin="0,0,22,0" />
                                                        <TextBlock Text="{Binding StarText}" Foreground="{StaticResource NeonInk.ImportantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Height="56" Margin="0,12,0,0">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Vault Storage" Style="{StaticResource DataCell}" VerticalAlignment="Center" />
                            <Grid Grid.Column="1" Height="10" VerticalAlignment="Center">
                                <Border Background="{StaticResource NeonInk.RaisedBrush}" CornerRadius="5" />
                                <Border Background="{StaticResource GreenBrush}" CornerRadius="5" Width="220" HorizontalAlignment="Left" />
                            </Grid>
                            <TextBlock Grid.Column="2" Text="{Binding StorageUsedText}" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" Margin="16,0,42,0" />
                            <TextBlock Grid.Column="3" Text="{Binding StorageTotalText}" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding ActiveScopeText}" Style="{StaticResource SmallLabel}" Margin="0,0,14,0" />
                                <TextBlock Text="{Binding RepairStatus}" Style="{StaticResource SmallLabel}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1,0,0,0">
                    <Grid Margin="12,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="230" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelBorder}" BorderBrush="{StaticResource NeonInk.ExperimentalBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,18">
                                        <RadioButton Content="Preview" GroupName="RightPanelTabs" IsChecked="{Binding IsPreviewTabSelected, Mode=TwoWay}" Style="{StaticResource RightPanelTabButton}" />
                                        <RadioButton Content="Details" GroupName="RightPanelTabs" IsChecked="{Binding IsDetailsTabSelected, Mode=TwoWay}" Style="{StaticResource RightPanelTabButton}" />
                                        <RadioButton Content="Relations" GroupName="RightPanelTabs" IsChecked="{Binding IsRelationsTabSelected, Mode=TwoWay}" Style="{StaticResource RightPanelTabButton}" Margin="0" />
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsPreviewTabSelected, Converter={StaticResource BoolToVisibility}}">
                                    <Border Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource NeonInk.ExperimentalBrush}" BorderThickness="1" CornerRadius="6" MinHeight="260" Margin="0,8,0,24" Padding="10">
                                        <Grid>
                                            <Image Source="{Binding SelectedPreview.Image}"
                                                   Stretch="Uniform"
                                                   MaxHeight="220"
                                                   Visibility="{Binding IsImagePreview, Converter={StaticResource BoolToVisibility}}" />

                                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" Visibility="{Binding IsTextPreview, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding SelectedPreview.Text}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </ScrollViewer>

                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="210" Visibility="{Binding IsGenericPreview, Converter={StaticResource BoolToVisibility}}">
                                                <Grid Width="96" Height="96" HorizontalAlignment="Center">
                                                    <Border Background="{Binding SelectedPreview.AccentBackground}" BorderBrush="{Binding SelectedPreview.AccentBrush}" BorderThickness="1" CornerRadius="8" />
                                                    <TextBlock Text="{Binding SelectedPreview.IconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               Foreground="{Binding SelectedPreview.AccentBrush}"
                                                               FontSize="36"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,-10,0,0" />
                                                    <Border Background="{StaticResource NeonInk.BaseBrush}"
                                                            BorderBrush="{Binding SelectedPreview.AccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="7,2"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding SelectedPreview.BadgeText}"
                                                                   Foreground="{Binding SelectedPreview.AccentBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding SelectedPreview.Title}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,12,0,0" />
                                                <TextBlock Text="{Binding SelectedPreview.Detail}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>

                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="210" Visibility="{Binding IsMissingPreview, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NeonInk.CriticalBrush}" FontSize="42" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedPreview.Title}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding SelectedPreview.Detail}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsRelationsTabSelected, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Relations" Foreground="{StaticResource NeonInk.StructureBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <Border Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource NeonInk.StructureBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,20">
                                        <StackPanel>
                                            <TextBlock Text="{Binding RelatedArtifactsSummary}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                            <ItemsControl ItemsSource="{Binding RelatedArtifacts}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding ReasonsText}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding Category}" Style="{StaticResource SmallLabel}" Margin="0,3,0,0" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding ScoreText}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                                <TextBlock Text="{Binding Size}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsDetailsTabSelected, Converter={StaticResource BoolToVisibility}}">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EditName}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.StarText}" Foreground="{StaticResource NeonInk.ImportantBrush}" FontSize="17" Margin="8,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="{Binding SelectedArtifact.SummaryText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,22" />

                                    <TextBlock Text="Editable Metadata" Foreground="{StaticResource NeonInk.FeaturedBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" />
                                    <ComboBox Text="{Binding EditCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding CategoryNames}"
                                              IsEditable="True"
                                              Style="{StaticResource EditorComboBox}"
                                              Margin="0,0,0,8" />
                                    <TextBox Text="{Binding EditTagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Comma-separated tags" />
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="62" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rating" Style="{StaticResource SmallLabel}" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding EditRating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <TextBlock Text="Operator Context" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <TextBlock Text="Retention reason" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditRetentionReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Retention reason" />
                                    <TextBlock Text="Why this matters" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditWhyThisMatters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Why this matters" />
                                    <TextBlock Text="Source provenance" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditSourceProvenance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Source or provenance" />
                                    <TextBlock Text="Acquisition method" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditAcquisitionMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Acquisition method" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Trust" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="Priority" Style="{StaticResource SmallLabel}" Margin="8,0,0,0" />
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox SelectedItem="{Binding EditTrustClassification, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding TrustClassificationOptions}"
                                                  Style="{StaticResource EditorComboBox}"
                                                  Margin="0,0,4,0"
                                                  ToolTip="Trust classification" />
                                        <ComboBox Grid.Column="1"
                                                  SelectedItem="{Binding EditRetentionPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding RetentionPriorityOptions}"
                                                  Style="{StaticResource EditorComboBox}"
                                                  Margin="4,0,0,0"
                                                  ToolTip="Retention priority" />
                                    </Grid>
                                    <TextBlock Text="Archive status" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <ComboBox SelectedItem="{Binding EditArchiveStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding ArchiveStatusOptions}"
                                              Style="{StaticResource EditorComboBox}"
                                              Margin="0,0,0,18"
                                              ToolTip="Archive status" />

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Path" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Path}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Type" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Type}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Created" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Created}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Modified" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.DateModified}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="BLAKE3" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedBlake3Display}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="SHA-256" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedSha256Display}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="File" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding StoredFileStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Hash" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.HashStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Text" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.ExtractedTextStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Preview" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.ThumbnailStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Index" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.ExtractedTextRelativePath}" Style="{StaticResource DataCell}" FontSize="12" TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Original" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.OriginalPath}" Style="{StaticResource DataCell}" FontSize="12" TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBlock Text="Tags" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding SelectedArtifact.Tags}" Margin="0,0,0,14">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Chip}">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Category" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Category}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Rating" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.RatingText}" Foreground="{StaticResource NeonInk.ImportantBrush}" FontSize="14" />
                                    </Grid>

                                    <TextBlock Text="Notes" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                    <TextBox Text="{Binding EditNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBox}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="88"
                                             Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EditStatus}" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Revert" Command="{Binding RevertArtifactCommand}" Style="{StaticResource ToolButton}" Margin="0,0,8,0" />
                                        <Button Grid.Column="2" Content="Save" Command="{Binding SaveArtifactCommand}" Style="{StaticResource ToolButton}" />
                                    </Grid>

                                    <TextBlock Text="ACTIONS" Style="{StaticResource SmallLabel}" Margin="0,0,0,14" />
                                    <UniformGrid Columns="4" Rows="2" Margin="0,0,0,8">
                                        <Button Command="{Binding OpenLocationCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE838;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Open&#x0a;Location" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding OpenFileCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE8A7;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Open&#x0a;File" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Click="RestoreArtifactButton_Click" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE8E5;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Restore&#x0a;Copy" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding ToggleStarCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE735;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Toggle&#x0a;Star" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding AddTagsCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE8EC;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Add&#x0a;Tags" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding HashCheckCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE72E;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Hash&#x0a;Check" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding QuarantineCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Quaran-&#x0a;tine" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Click="DeleteArtifactButton_Click" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" HorizontalAlignment="Center" Foreground="{StaticResource NeonInk.CriticalBrush}" /><TextBlock Text="Delete&#x0a;Forever" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                    </UniformGrid>
                                    <TextBlock Text="{Binding ActionStatus}" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,10,0,0">
                            <Grid Margin="14,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="VAULT HEALTH" Foreground="{StaticResource NeonInk.SuccessBrush}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VaultHealthSummary}" Style="{StaticResource SmallLabel}" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding VaultMaintenanceStatus}" Style="{StaticResource SmallLabel}" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding VaultMaintenanceDetail}" Style="{StaticResource SmallLabel}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" MaxWidth="520" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Analyze" Command="{Binding RepairCatalogCommand}" ToolTip="Analyze vault health without mutating files" Style="{StaticResource ToolButton}" Height="30" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,12,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Vault" Style="{StaticResource SmallLabel}" />
                                    <TextBlock Grid.Column="1" Text="{Binding VaultRootPath}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="1" Text="Catalog" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CatalogPath}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,7,0,0" />

                                    <TextBlock Grid.Row="2" Text="Intake" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IngestModeText}" Style="{StaticResource DataCell}" FontSize="12" Margin="0,7,0,0" />

                                    <TextBlock Grid.Row="3" Text="Backup" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastBackupDisplay}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,7,0,0" />

                                    <Border Grid.Row="4" Grid.ColumnSpan="2" Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="6" Margin="0,12,0,0" Padding="8">
                                        <ScrollViewer MaxHeight="88" VerticalScrollBarVisibility="Auto">
                                            <ItemsControl ItemsSource="{Binding RepairCandidates}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Margin="0,0,6,0" VerticalAlignment="Center" />
                                                                    <TextBlock Text="{Binding FindingType}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                                <TextBlock Text="{Binding Subject}" Style="{StaticResource SmallLabel}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding ActionType}" Foreground="{StaticResource AccentBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding ProposedAction}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="8,0,0,0" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding RiskLevel}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                                <TextBlock Text="{Binding ApprovalText}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding MutatesCatalog, StringFormat=Catalog: {0}}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding TouchesRetainedFiles, StringFormat=Files: {0}}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </Border>

                                    <Border Grid.Row="5" Grid.ColumnSpan="2" Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="6" Margin="0,8,0,0" Padding="8">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="Repair History" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" />
                                                <TextBlock Grid.Column="1" Text="{Binding RepairHistorySummary}" Style="{StaticResource SmallLabel}" FontSize="11" />
                                            </Grid>
                                            <ScrollViewer MaxHeight="76" VerticalScrollBarVisibility="Auto">
                                                <ItemsControl ItemsSource="{Binding RepairHistory}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,0,0,8">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="70" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Text="{Binding Result}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                                                    <TextBlock Text="{Binding Subject}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding Detail}" Style="{StaticResource SmallLabel}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                                </StackPanel>
                                                                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                                    <TextBlock Text="{Binding ActionType}" Style="{StaticResource SmallLabel}" FontSize="11" HorizontalAlignment="Right" />
                                                                    <TextBlock Text="{Binding Timestamp}" Style="{StaticResource SmallLabel}" FontSize="11" HorizontalAlignment="Right" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>
                                    </Border>
                                </Grid>

                                <WrapPanel Grid.Row="2">
                                    <Button Content="Vault..." Click="ChooseVaultButton_Click" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="{Binding IngestModeText}" Command="{Binding ToggleIngestModeCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Backup" Command="{Binding BackupCatalogCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Analyze" Command="{Binding RepairCatalogCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Apply Selected" Click="ApplyRepairCandidatesButton_Click" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Rescan" Command="{Binding RescanVaultCommand}" Style="{StaticResource ToolButton}" Height="30" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
