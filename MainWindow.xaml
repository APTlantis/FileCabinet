<Window x:Class="MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:FileCabinet"
        Title="FileCabinet - Personal Vault &amp; Artifact Manager"
        Width="1680"
        Height="1040"
        MinWidth="1180"
        MinHeight="720"
        Icon="Assets/FileCabinet.ico"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource WindowBgBrush}"
        Foreground="{StaticResource PrimaryTextBrush}">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="0" ResizeBorderThickness="6" GlassFrameThickness="0" CornerRadius="0" />
    </WindowChrome.WindowChrome>
    <Window.Resources>
        <local:BindingProxy x:Key="VmProxy" Data="{Binding}" />

        <Style x:Key="IconText" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
        </Style>

        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        </Style>

        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style x:Key="DataCell" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>

        <Style x:Key="PanelBorder" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBgBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>

        <Style x:Key="ChromeButton" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="34" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Background" Value="{StaticResource NeonInk.SoftBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RightPanelTabButton" TargetType="RadioButton">
            <Setter Property="Height" Value="32" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="8,0" />
            <Setter Property="Margin" Value="0,0,6,6" />
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.PipelineBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource NeonInk.FeaturedBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavCommandButton" TargetType="Button">
            <Setter Property="Height" Value="30" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        </Style>

        <Style x:Key="NavListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,2" />
            <Setter Property="Padding" Value="9,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="Transparent"
                                CornerRadius="5"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FilterListBoxItem" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root" Background="Transparent" CornerRadius="5" Padding="4,3">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.RaisedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="Chip" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource NeonInk.SoftBrush}" />
            <Setter Property="CornerRadius" Value="5" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="Margin" Value="0,0,6,6" />
        </Style>

        <Style x:Key="EditorTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
        </Style>

        <Style x:Key="EditorComboBoxItem" TargetType="ComboBoxItem">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="EditorComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="ItemContainerStyle" Value="{StaticResource EditorComboBoxItem}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Focusable="False"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="24" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0" />
                                                <TextBlock Grid.Column="1"
                                                           Text="&#xE70D;"
                                                           FontFamily="Segoe MDL2 Assets"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="10" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.SoftBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="ContentSite"
                                              Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Left"
                                              VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              IsHitTestVisible="False">
                                <ContentPresenter.Resources>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                    </Style>
                                </ContentPresenter.Resources>
                            </ContentPresenter>

                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="{TemplateBinding Padding}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource PrimaryTextBrush}"
                                     CaretBrush="{StaticResource PrimaryTextBrush}"
                                     FontSize="{TemplateBinding FontSize}"
                                     Visibility="Hidden"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"
                                     HorizontalAlignment="Stretch"
                                     VerticalAlignment="Center" />

                            <Popup x:Name="Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border Background="{StaticResource CardAltBrush}"
                                        BorderBrush="{StaticResource BorderDimBrush}"
                                        BorderThickness="1"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <ScrollViewer>
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.6" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource NeonInk.BaseBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="GridLinesVisibility" Value="None" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="34" />
            <Setter Property="ColumnHeaderHeight" Value="34" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="CanUserResizeRows" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="SelectionUnit" Value="FullRow" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource NeonInk.BaseBrush}" />
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderDimBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="16,0" />
            <Setter Property="Foreground" Value="{StaticResource SecondaryTextBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="{StaticResource NeonInk.BaseBrush}" />
            <Style.Triggers>
                <Trigger Property="AlternationIndex" Value="1">
                    <Setter Property="Background" Value="{StaticResource CardAltBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                    <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="{StaticResource ShellGradientBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="32" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="{StaticResource NeonInk.VoidBrush}" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="12,0,0,0">
                    <Image Source="Assets/FileCabinetLogoMark.png"
                           Width="18"
                           Height="18"
                           Stretch="Uniform"
                           VerticalAlignment="Center" />
                    <TextBlock Text="FileCabinet - Personal Vault &amp; Artifact Manager"
                               Margin="9,0,0,0"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="13"
                               VerticalAlignment="Center" />
                    <Menu Background="Transparent"
                          Foreground="{StaticResource SecondaryTextBrush}"
                          Margin="18,0,0,0"
                          VerticalAlignment="Center">
                        <MenuItem Header="Settings" Command="{Binding ShowSettingsCommand}" ToolTip="Choose which hashes FileCabinet records and verifies." />
                        <MenuItem Header="Help">
                            <MenuItem Header="User Guide" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="README.md" ToolTip="Open the main FileCabinet user guide." />
                            <MenuItem Header="Retention Choices" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — The Deliberate Retention Tradeoff.md" ToolTip="Explain why FileCabinet keeps retained files deliberately instead of cleaning them up automatically." />
                            <MenuItem Header="Trust and Verification" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Trust and Verification Model.md" ToolTip="Explain how FileCabinet uses hashes, paths, and catalog data to verify artifacts." />
                            <MenuItem Header="Hash Choices" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Why SHA-256 and BLAKE3.md" ToolTip="Explain the default integrity hashes and when compatibility hashes are useful." />
                            <MenuItem Header="Repair and Recovery" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Repair and Recovery Guide.md" ToolTip="Explain health findings, safe repairs, and review-only issues." />
                            <MenuItem Header="Roadmap" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenHelpDocumentCommand}" CommandParameter="docs\FileCabinet — Deterministic Vault Roadmap.md" ToolTip="Open planned reliability and preservation improvements." />
                            <Separator />
                            <MenuItem Header="Open Docs Folder" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding OpenDocsFolderCommand}" />
                            <MenuItem Header="About FileCabinet" Foreground="{StaticResource NeonInk.InverseTextBrush}" Command="{Binding ShowAboutCommand}" />
                        </MenuItem>
                    </Menu>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Content="&#xE921;" Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" />
                    <Button Content="&#xE922;" Style="{StaticResource ChromeButton}" Click="MaximizeButton_Click" />
                    <Button Content="&#xE8BB;" Style="{StaticResource ChromeButton}" Click="CloseButton_Click" />
                </StackPanel>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="235" MinWidth="210" />
                    <ColumnDefinition Width="*" MinWidth="720" />
                    <ColumnDefinition Width="330" MinWidth="300" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,0,1,0">
                    <Grid Margin="14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <TextBlock Text="VAULTS" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="&#xE8B7;" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Width="30" Height="26" Padding="0" Click="ChooseVaultButton_Click" ToolTip="Set selected vault folder" />
                                <Button Content="&#xE738;" Command="{Binding RemoveCurrentVaultCommand}" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Width="30" Height="26" Padding="0" Margin="6,0,0,0" ToolTip="Remove selected vault from list" />
                            </StackPanel>
                        </Grid>

                        <ListBox Grid.Row="1"
                                 ItemsSource="{Binding Vaults}"
                                 SelectedItem="{Binding CurrentVault}"
                                 Style="{StaticResource NavListBox}"
                                 ItemContainerStyle="{StaticResource NavListBoxItem}"
                                 Margin="0,0,0,14">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Grid.Column="1" Text="{Binding DisplayName}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,1,0,1" Padding="0,13">
                            <StackPanel>
                                <TextBlock Text="NAVIGATION" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                <Button Command="{Binding ClearFiltersCommand}" Style="{StaticResource NavCommandButton}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE80F;" Style="{StaticResource IconText}" Foreground="{StaticResource AccentBrush}" />
                                        <TextBlock Text="Dashboard" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                                <Button Content="All Items" Command="{Binding ShowAllItemsCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,7,0,0" />
                                <Button Content="Recent" Command="{Binding ShowRecentCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Grid Margin="0,10,0,0">
                                    <Button Content="Inbox" Command="{Binding ShowRecentCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource AccentBrush}" CornerRadius="9" Padding="8,2">
                                        <TextBlock Text="{Binding InboxCountText}" FontSize="11" Foreground="{StaticResource NeonInk.InverseTextBrush}" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Button Content="Starred" Command="{Binding ShowStarredCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource NeonInk.ImportantBrush}" CornerRadius="9" Padding="8,2">
                                        <TextBlock Text="{Binding StarredCountText}" FontSize="11" Foreground="{StaticResource NeonInk.InverseTextBrush}" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,10,0,0">
                                    <Button Content="Quarantine" Command="{Binding ShowQuarantineCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" />
                                    <Border HorizontalAlignment="Right" Background="{StaticResource NeonInk.CriticalBrush}" CornerRadius="9" Padding="8,2">
                                        <TextBlock Text="{Binding QuarantineCountText}" FontSize="11" Foreground="{StaticResource NeonInk.InverseTextBrush}" />
                                    </Border>
                                </Grid>
                                <Button Content="Unverified" Command="{Binding ShowUnverifiedCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,10,0,0" />
                                <Button Content="Missing Preview" Command="{Binding ShowMissingPreviewCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Repair Needed" Command="{Binding ShowRepairNeededCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Duplicate Candidates" Command="{Binding ShowDuplicateCandidatesCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Same Source Batch" Command="{Binding ShowSameSourceBatchCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Button Content="Large Artifacts" Command="{Binding ShowLargeArtifactsCommand}" Style="{StaticResource ToolButton}" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                                <Border BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="0,1,0,0" Margin="0,12,0,4" />
                                <Button Command="{Binding ShowVaultHealthCommand}" Style="{StaticResource NavCommandButton}">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE9D9;" Style="{StaticResource IconText}" Foreground="{StaticResource NeonInk.FeaturedBrush}" />
                                        <TextBlock Text="Vault Health Dashboard" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" Margin="10,0,0,0" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>

                        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto" Margin="0,13,0,13">
                            <StackPanel>
                                <TextBlock Text="CATEGORIES" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                <ListBox ItemsSource="{Binding Categories}"
                                         SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                         Style="{StaticResource NavListBox}"
                                         ItemContainerStyle="{StaticResource FilterListBoxItem}">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" Style="{StaticResource DataCell}" />
                                                <TextBlock Grid.Column="1" Text="{Binding Count}" Style="{StaticResource DataCell}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <TextBlock Text="TAGS" Style="{StaticResource SmallLabel}" Margin="0,12,0,10" />
                                <ListBox ItemsSource="{Binding FilteredTags}"
                                         SelectedItem="{Binding SelectedTag, Mode=TwoWay}"
                                         Style="{StaticResource NavListBox}">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="0" />
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="Root" Background="Transparent" CornerRadius="5">
                                                            <ContentPresenter />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="Root" Property="Background" Value="{StaticResource NeonInk.NavigationSurfaceBrush}" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource Chip}">
                                                <TextBlock Text="{Binding}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <Border Background="{StaticResource NeonInk.PanelBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Height="32" Margin="0,8,0,0">
                                    <Grid Margin="9,0" VerticalAlignment="Center">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="18" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="&#xE721;" Style="{StaticResource IconText}" FontSize="12" Foreground="{StaticResource MutedTextBrush}" />
                                        <TextBox Grid.Column="1"
                                                 Text="{Binding TagSearchText, UpdateSourceTrigger=PropertyChanged}"
                                                 Background="Transparent"
                                                 BorderThickness="0"
                                                 Foreground="{StaticResource PrimaryTextBrush}"
                                                 FontSize="12"
                                                 Padding="0"
                                                 VerticalContentAlignment="Center"
                                                 ToolTip="Filter visible tags" />
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>

                        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,12,0,0">
                            <Button Content="&#xE713;" Command="{Binding ShowSettingsCommand}" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Width="30" Height="28" Padding="0" ToolTip="Settings summary" />
                            <Button Content="Settings" Command="{Binding ShowSettingsCommand}" Style="{StaticResource ToolButton}" Height="28" Margin="9,0,0,0" />
                        </StackPanel>
                    </Grid>
                </Border>

                <Grid Grid.Column="1" Margin="16,14">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentVaultTitle}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="16" FontWeight="SemiBold" />
                            <TextBlock Text="  •  " Foreground="{StaticResource MutedTextBrush}" FontSize="13" />
                            <TextBlock Text="{Binding CurrentVaultSummary}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="13" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                            <Border Width="300" Height="34" Background="{StaticResource NeonInk.PanelBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Margin="0,0,8,0">
                                <Grid Margin="11,0" VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="&#xE721;" Style="{StaticResource IconText}" FontSize="12" />
                                    <TextBox Grid.Column="1"
                                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             Foreground="{StaticResource PrimaryTextBrush}"
                                             FontSize="12"
                                             Padding="0"
                                             VerticalContentAlignment="Center"
                                             ToolTip="Search vault by name, type, category, path, notes, hash, or tag" />
                                </Grid>
                            </Border>
                            <Button Content="&#xE72C;" Command="{Binding RefreshCommand}" ToolTip="Refresh vault" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" />
                            <Button Content="&#xE8FD;" Command="{Binding SortByNameCommand}" ToolTip="Sort by name" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                            <Button Content="&#xE787;" Command="{Binding SortByDateCommand}" ToolTip="Sort by date" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                            <Button Content="&#xE713;" Command="{Binding ShowSettingsCommand}" ToolTip="Settings summary" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                        </StackPanel>
                    </Grid>

                    <Grid Grid.Row="1" Grid.RowSpan="3" Visibility="{Binding IsVaultHealthWorkspaceVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" BorderBrush="{StaticResource NeonInk.SuccessBrush}" Margin="0,0,0,12">
                            <Grid Margin="16,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Vault Health" Foreground="{StaticResource NeonInk.SuccessBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding VaultHealthSummary}" Style="{StaticResource DataCell}" Margin="0,6,0,0" />
                                    <TextBlock Text="{Binding VaultHealthBreakdown}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                    <TextBlock Text="{Binding VaultMaintenanceStatus}" Style="{StaticResource SmallLabel}" Margin="0,8,0,0" />
                                    <TextBlock Text="{Binding VaultMaintenanceDetail}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                    <ProgressBar Height="7" Minimum="0" Maximum="100" Value="{Binding VaultMaintenanceProgress, Mode=OneWay}" Margin="0,8,0,0" />
                                </StackPanel>
                                <WrapPanel Grid.Column="1" HorizontalAlignment="Right" MaxWidth="460" Margin="16,0,0,0">
                                    <Button Content="Analyze Health" Command="{Binding RepairCatalogCommand}" ToolTip="Run fast metadata-first health analysis without reading large retained files." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                    <Button Content="Verify small hashes" Command="{Binding VerifySmallHashesCommand}" ToolTip="Verify existing hashes for retained files up to 1 GB." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                    <Button Content="Full Rescan &amp; Orphan Recovery" Command="{Binding RescanVaultCommand}" ToolTip="Refresh generated assets, adopt recoverable orphan files, then run health analysis." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                    <Button Content="Apply Selected Repairs" Click="ApplyRepairCandidatesButton_Click" ToolTip="Apply selected automatic repairs after confirmation." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <UniformGrid Grid.Row="1" Rows="1" Columns="5" Margin="0,0,0,12">
                            <Border Style="{StaticResource PanelBorder}" Height="78" Margin="0,0,10,0"><StackPanel Margin="14" VerticalAlignment="Center"><TextBlock Text="{Binding HealthFindingCountText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="Findings" Style="{StaticResource SmallLabel}" /></StackPanel></Border>
                            <Border Style="{StaticResource PanelBorder}" Height="78" Margin="0,0,10,0"><StackPanel Margin="14" VerticalAlignment="Center"><TextBlock Text="{Binding HealthRepairableCountText}" Foreground="{StaticResource NeonInk.SuccessBrush}" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="Automatic" Style="{StaticResource SmallLabel}" /></StackPanel></Border>
                            <Border Style="{StaticResource PanelBorder}" Height="78" Margin="0,0,10,0"><StackPanel Margin="14" VerticalAlignment="Center"><TextBlock Text="{Binding HealthReviewOnlyCountText}" Foreground="{StaticResource NeonInk.ImportantBrush}" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="Review-only" Style="{StaticResource SmallLabel}" /></StackPanel></Border>
                            <Border Style="{StaticResource PanelBorder}" Height="78" Margin="0,0,10,0"><StackPanel Margin="14" VerticalAlignment="Center"><TextBlock Text="{Binding HealthSelectedCountText}" Foreground="{StaticResource AccentBrush}" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="Selected" Style="{StaticResource SmallLabel}" /></StackPanel></Border>
                            <Border Style="{StaticResource PanelBorder}" Height="78"><StackPanel Margin="14" VerticalAlignment="Center"><TextBlock Text="{Binding HealthDeferredHashCountText}" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="22" FontWeight="SemiBold" /><TextBlock Text="Large hash reads deferred" Style="{StaticResource SmallLabel}" /></StackPanel></Border>
                        </UniformGrid>

                        <Border Grid.Row="2" Style="{StaticResource PanelBorder}">
                            <TabControl Background="Transparent" BorderThickness="0" Margin="12">
                                <TabItem Header="Overview">
                                    <Grid Margin="8,12,8,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ItemsControl ItemsSource="{Binding HealthRiskBreakdownRows}" Margin="0,0,12,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,9">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="120" />
                                                            <ColumnDefinition Width="170" />
                                                            <ColumnDefinition Width="50" />
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource DataCell}" />
                                                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center">
                                                            <Border Background="{StaticResource NeonInk.RaisedBrush}" CornerRadius="4" />
                                                            <Border Background="{Binding AccentBrush}" Width="{Binding PercentWidth}" HorizontalAlignment="Left" CornerRadius="4" />
                                                        </Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding HealthFindingBreakdownRows}" Margin="0,0,12,0">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,9">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="170" /><ColumnDefinition Width="50" /></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource DataCell}" TextTrimming="CharacterEllipsis" />
                                                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center"><Border Background="{StaticResource NeonInk.RaisedBrush}" CornerRadius="4" /><Border Background="{Binding AccentBrush}" Width="{Binding PercentWidth}" HorizontalAlignment="Left" CornerRadius="4" /></Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        <ItemsControl Grid.Column="2" ItemsSource="{Binding HealthRepairActionBreakdownRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,9">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="150" /><ColumnDefinition Width="170" /><ColumnDefinition Width="50" /></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Label}" Style="{StaticResource DataCell}" TextTrimming="CharacterEllipsis" />
                                                        <Grid Grid.Column="1" Height="8" VerticalAlignment="Center"><Border Background="{StaticResource NeonInk.RaisedBrush}" CornerRadius="4" /><Border Background="{Binding AccentBrush}" Width="{Binding PercentWidth}" HorizontalAlignment="Left" CornerRadius="4" /></Grid>
                                                        <TextBlock Grid.Column="2" Text="{Binding CountText}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Repairs">
                                    <Grid Margin="8,12,8,8">
                                        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                                        <WrapPanel Margin="0,0,0,10">
                                            <Button Content="Select safe automatic" Command="{Binding SelectSafeRepairCandidatesCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Select visible" Command="{Binding SelectVisibleRepairCandidatesCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Clear visible" Command="{Binding ClearVisibleRepairCandidatesCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Select all automatic" Command="{Binding SelectAllAutomaticRepairCandidatesCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Select RecomputeHash" Command="{Binding SelectRepairActionCommand}" CommandParameter="RecomputeHash" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Select ReExtractText" Command="{Binding SelectRepairActionCommand}" CommandParameter="ReExtractText" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Select RebindPath" Command="{Binding SelectRepairActionCommand}" CommandParameter="RebindPath" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                            <Button Content="Clear all" Command="{Binding ClearRepairSelectionCommand}" Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                        </WrapPanel>
                                        <DataGrid Grid.Row="1" ItemsSource="{Binding FilteredRepairCandidates}" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="Apply" Width="58"><DataGridTemplateColumn.CellTemplate><DataTemplate><CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanRepairAutomatically}" HorizontalAlignment="Center" /></DataTemplate></DataGridTemplateColumn.CellTemplate></DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Group" Binding="{Binding RepairGroup}" Width="140" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Action" Binding="{Binding ActionType}" Width="130" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Type" Binding="{Binding FindingType}" Width="150" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="*" IsReadOnly="True" />
                                                <DataGridTextColumn Header="State" Binding="{Binding SelectionState}" Width="170" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </Grid>
                                </TabItem>
                                <TabItem Header="Findings">
                                    <DataGrid ItemsSource="{Binding VaultHealthFindings}" Margin="8,12,8,8" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="90" />
                                            <DataGridTextColumn Header="Type" Binding="{Binding FindingType}" Width="170" />
                                            <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="220" />
                                            <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="*" />
                                            <DataGridTextColumn Header="Proposed Action" Binding="{Binding ProposedAction}" Width="280" />
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </TabItem>
                                <TabItem Header="History">
                                    <ScrollViewer Margin="8,12,8,8" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding RepairHistory}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,0,0,10">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="90" /><ColumnDefinition Width="*" /><ColumnDefinition Width="160" /></Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Result}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" />
                                                        <StackPanel Grid.Column="1" Margin="8,0"><TextBlock Text="{Binding Subject}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" /><TextBlock Text="{Binding Detail}" Style="{StaticResource SmallLabel}" /></StackPanel>
                                                        <StackPanel Grid.Column="2" HorizontalAlignment="Right"><TextBlock Text="{Binding ActionType}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" /><TextBlock Text="{Binding Timestamp}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" /></StackPanel>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>
                            </TabControl>
                        </Border>
                    </Grid>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Stats}" Margin="0,0,0,14" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibility}}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" Columns="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PanelBorder}" Height="88" Margin="0,0,10,0">
                                    <Grid Margin="18,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="56" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Ellipse Width="44" Height="44" Fill="{Binding IconBackground}" VerticalAlignment="Center" />
                                        <TextBlock Text="{Binding Icon}" Style="{StaticResource IconText}" Foreground="{Binding IconBrush}" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Value}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="22" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding Label}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Row="2" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="390" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.35*" MinWidth="500" />
                            <ColumnDefinition Width="12" />
                            <ColumnDefinition Width="0.95*" MinWidth="360" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource PanelBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="230" MinHeight="230" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Border Margin="12"
                                        BorderBrush="{StaticResource NeonInk.ProcessBrush}"
                                        BorderThickness="1.5"
                                        CornerRadius="6"
                                        Background="{StaticResource NeonInk.SoftBrush}"
                                        AllowDrop="True"
                                        Drop="DropZone_Drop"
                                        MouseLeftButtonUp="DropZone_MouseLeftButtonUp">
                                    <Grid Margin="18,12">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="DROP ZONE - INGEST FILES" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center" />

                                        <StackPanel Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE898;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NeonInk.PipelineBrush}" FontSize="52" HorizontalAlignment="Center" />
                                            <TextBlock Text="Drag &amp; drop files or folders here" Foreground="{StaticResource PrimaryTextBrush}" FontSize="15" HorizontalAlignment="Center" Margin="0,8,0,0" />
                                            <TextBlock Text="or click to browse" Foreground="{StaticResource NeonInk.FeaturedBrush}" FontSize="13" HorizontalAlignment="Center" Margin="0,7,0,0" />
                                            <Border Background="{StaticResource NeonInk.PipelineBrush}" BorderBrush="{StaticResource NeonInk.FeaturedBrush}" BorderThickness="1" CornerRadius="5" Padding="10,4" HorizontalAlignment="Center" Margin="0,8,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="INTAKE MODE:" Foreground="{StaticResource MutedTextBrush}" FontSize="11" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding IngestModeText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="11" FontWeight="SemiBold" Margin="6,0,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Row="2" HorizontalAlignment="Center">
                                            <TextBlock Text="{Binding IngestStatus}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Center" />
                                            <ProgressBar Width="360"
                                                         Height="8"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding IngestProgress}"
                                                         Visibility="{Binding IsIngesting, Converter={StaticResource BoolToVisibility}}"
                                                         Margin="0,5,0,0" />
                                            <TextBlock Text="{Binding IngestDetail}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" MaxWidth="520" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <Grid Grid.Row="1" Margin="18,2,18,18">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="1" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Ingest Options" Style="{StaticResource SectionTitle}" Margin="0,0,0,9" />
                                        <WrapPanel>
                                            <Button Command="{Binding ToggleIngestModeCommand}" Style="{StaticResource ToolButton}" MinHeight="52" Margin="0,0,8,8">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding IngestModeText}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" />
                                                    <TextBlock Text="{Binding DuplicatePolicyText}" Foreground="{StaticResource MutedTextBrush}" FontSize="11" />
                                                </StackPanel>
                                            </Button>
                                            <Border Background="{StaticResource NeonInk.PanelBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="5" Padding="12,8" Margin="0,0,8,8">
                                                <TextBlock Text="{Binding IngestModeDetail}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" TextWrapping="Wrap" Width="180" />
                                            </Border>
                                        </WrapPanel>
                                    </StackPanel>
                                    <Border Grid.Column="1" Background="{StaticResource BorderDimBrush}" Margin="10,0" />
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Auto-Process" Style="{StaticResource SectionTitle}" Margin="0,0,0,9" />
                                        <TextBlock Text="{Binding ActiveHashSummary}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,7" />
                                        <TextBlock Text="{Binding IngestModeDetail}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,10" />
                                        <Button Content="Hash Settings" Command="{Binding ShowSettingsCommand}" ToolTip="Choose which integrity hashes are computed during ingest, repair, and health checks." Style="{StaticResource ToolButton}" HorizontalAlignment="Left" />
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>

                        <Border Grid.Row="0" Grid.Column="2" Style="{StaticResource PanelBorder}">
                            <StackPanel Margin="16">
                                <TextBlock Text="RECENT ACTIVITY" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,18" />
                                <ItemsControl ItemsSource="{Binding Activities}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,16">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="36" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Border Width="22" Height="22" CornerRadius="11" Background="{Binding IconBackground}">
                                                    <TextBlock Text="{Binding Icon}" FontFamily="Segoe MDL2 Assets" Foreground="{Binding IconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="11" />
                                                </Border>
                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Text="{Binding ActionText}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" />
                                                    <TextBlock Text="{Binding DetailText}" Style="{StaticResource SmallLabel}" />
                                                </StackPanel>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="View all activity..." Foreground="{StaticResource AccentBrush}" FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3" Style="{StaticResource PanelBorder}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="40" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="16,0">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FilterTitle}" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                        <Button Content="Clear" Command="{Binding ClearFiltersCommand}" Style="{StaticResource ToolButton}" Height="26" Margin="12,0,0,0" Padding="10,0" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <Button Content="&#xE8FD;" Command="{Binding SortByNameCommand}" ToolTip="Sort by name" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" />
                                        <Button Content="&#xE787;" Command="{Binding SortByDateCommand}" ToolTip="Sort by modified date" Style="{StaticResource ToolButton}" FontFamily="Segoe MDL2 Assets" Margin="8,0,0,0" />
                                        <Button Content="{Binding ColumnPresetText}" Command="{Binding CycleColumnPresetCommand}" ToolTip="Cycle visible columns" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                                        <Button Content="{Binding DensityText}" Command="{Binding ToggleDensityCommand}" Style="{StaticResource ToolButton}" Margin="8,0,0,0" />
                                        <Button Content="Health  &#xE9D9;" Command="{Binding ShowVaultHealthCommand}" ToolTip="Open vault health, analysis, and repair tools." Style="{StaticResource ToolButton}" Background="{StaticResource NeonInk.PipelineBrush}" BorderBrush="{StaticResource NeonInk.FeaturedBrush}" Margin="8,0,0,0" />
                                    </StackPanel>
                                </Grid>
                                <DataGrid Grid.Row="1"
                                          ItemsSource="{Binding FilteredArtifacts}"
                                          SelectedItem="{Binding SelectedArtifact, Mode=TwoWay}"
                                          RowHeight="{Binding ArtifactRowHeight}"
                                          EnableRowVirtualization="True"
                                          EnableColumnVirtualization="True"
                                          VirtualizingPanel.IsVirtualizing="True"
                                          VirtualizingPanel.VirtualizationMode="Recycling"
                                          AlternationCount="2">
                                    <DataGrid.Columns>
                                        <DataGridTemplateColumn Header="Name" SortMemberPath="Name" Width="2.2*">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Border Width="20" Height="20" CornerRadius="10" Background="{Binding IconBackground}" Margin="0,0,12,0" ToolTip="{Binding MaterialSymbolName}">
                                                            <TextBlock Text="{Binding IconGlyph}" FontFamily="Segoe MDL2 Assets" Foreground="{Binding IconBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Name}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" />
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="1*" Visibility="{Binding Data.ShowTypeColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="1.45*" Visibility="{Binding Data.ShowCategoryColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTextColumn Header="Size" Binding="{Binding Size}" SortMemberPath="SizeBytes" Width="0.9*" Visibility="{Binding Data.ShowSizeColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTextColumn Header="Date Modified" Binding="{Binding DateModified}" Width="1.15*" Visibility="{Binding Data.ShowDateColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}" />
                                        <DataGridTemplateColumn Header="Tags" Width="1.9*" Visibility="{Binding Data.ShowTagsColumn, Source={StaticResource VmProxy}, Converter={StaticResource BoolToVisibility}}">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <Grid>
                                                        <TextBlock Text="{Binding TagsText}" Style="{StaticResource DataCell}" Margin="0,0,22,0" />
                                                        <TextBlock Text="{Binding StarText}" Foreground="{StaticResource NeonInk.ImportantBrush}" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                                    </Grid>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Height="56" Margin="0,12,0,0" Visibility="{Binding IsDashboardVisible, Converter={StaticResource BoolToVisibility}}">
                        <Grid Margin="16,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Vault Storage" Style="{StaticResource DataCell}" VerticalAlignment="Center" />
                            <Grid Grid.Column="1" Height="10" VerticalAlignment="Center">
                                <Border Background="{StaticResource NeonInk.RaisedBrush}" CornerRadius="5" />
                                <Border Background="{StaticResource GreenBrush}" CornerRadius="5" Width="220" HorizontalAlignment="Left" />
                            </Grid>
                            <TextBlock Grid.Column="2" Text="{Binding StorageUsedText}" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" Margin="16,0,42,0" />
                            <TextBlock Grid.Column="3" Text="{Binding StorageTotalText}" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock Text="{Binding ActiveScopeText}" Style="{StaticResource SmallLabel}" Margin="0,0,14,0" />
                                <TextBlock Text="{Binding RepairStatus}" Style="{StaticResource SmallLabel}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <Border Grid.Column="2" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1,0,0,0">
                    <Grid Margin="12,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="230" />
                        </Grid.RowDefinitions>
                        <Border Style="{StaticResource PanelBorder}" BorderBrush="{StaticResource NeonInk.ExperimentalBrush}">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                                <StackPanel Margin="16">
                                    <UniformGrid Columns="3" Margin="0,0,0,12">
                                        <RadioButton Content="Preview" GroupName="RightPanelTabs" IsChecked="{Binding IsPreviewTabSelected, Mode=TwoWay}" Style="{StaticResource RightPanelTabButton}" />
                                        <RadioButton Content="Details" GroupName="RightPanelTabs" IsChecked="{Binding IsDetailsTabSelected, Mode=TwoWay}" Style="{StaticResource RightPanelTabButton}" Margin="0,0,0,6" />
                                        <RadioButton Content="Relations" GroupName="RightPanelTabs" IsChecked="{Binding IsRelationsTabSelected, Mode=TwoWay}" Style="{StaticResource RightPanelTabButton}" Margin="0,0,0,6" />
                                    </UniformGrid>

                                    <StackPanel Visibility="{Binding IsPreviewTabSelected, Converter={StaticResource BoolToVisibility}}">
                                    <Border Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource NeonInk.ExperimentalBrush}" BorderThickness="1" CornerRadius="6" MinHeight="260" Margin="0,8,0,24" Padding="10">
                                        <Grid>
                                            <Image Source="{Binding SelectedPreview.Image}"
                                                   Stretch="Uniform"
                                                   MaxHeight="220"
                                                   Visibility="{Binding IsImagePreview, Converter={StaticResource BoolToVisibility}}" />

                                            <ScrollViewer MaxHeight="220" VerticalScrollBarVisibility="Auto" Visibility="{Binding IsTextPreview, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="{Binding SelectedPreview.Text}"
                                                           Foreground="{StaticResource SecondaryTextBrush}"
                                                           FontFamily="Consolas"
                                                           FontSize="11"
                                                           TextWrapping="Wrap" />
                                            </ScrollViewer>

                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="210" Visibility="{Binding IsGenericPreview, Converter={StaticResource BoolToVisibility}}">
                                                <Grid Width="96" Height="96" HorizontalAlignment="Center">
                                                    <Border Background="{Binding SelectedPreview.AccentBackground}" BorderBrush="{Binding SelectedPreview.AccentBrush}" BorderThickness="1" CornerRadius="8" />
                                                    <TextBlock Text="{Binding SelectedPreview.IconGlyph}"
                                                               FontFamily="Segoe MDL2 Assets"
                                                               Foreground="{Binding SelectedPreview.AccentBrush}"
                                                               FontSize="36"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"
                                                               Margin="0,-10,0,0" />
                                                    <Border Background="{StaticResource NeonInk.BaseBrush}"
                                                            BorderBrush="{Binding SelectedPreview.AccentBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="4"
                                                            Padding="7,2"
                                                            HorizontalAlignment="Center"
                                                            VerticalAlignment="Bottom"
                                                            Margin="0,0,0,10">
                                                        <TextBlock Text="{Binding SelectedPreview.BadgeText}"
                                                                   Foreground="{Binding SelectedPreview.AccentBrush}"
                                                                   FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   TextAlignment="Center" />
                                                    </Border>
                                                </Grid>
                                                <TextBlock Text="{Binding SelectedPreview.Title}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,12,0,0" />
                                                <TextBlock Text="{Binding SelectedPreview.Detail}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>

                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="210" Visibility="{Binding IsMissingPreview, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE783;" FontFamily="Segoe MDL2 Assets" Foreground="{StaticResource NeonInk.CriticalBrush}" FontSize="42" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedPreview.Title}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" TextAlignment="Center" TextWrapping="Wrap" Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding SelectedPreview.Detail}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextAlignment="Center" TextWrapping="Wrap" Margin="0,6,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsRelationsTabSelected, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Relations" Foreground="{StaticResource NeonInk.StructureBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <Border Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource NeonInk.StructureBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,20">
                                        <StackPanel>
                                            <TextBlock Text="{Binding RelatedArtifactsSummary}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                            <ItemsControl ItemsSource="{Binding RelatedArtifacts}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Grid Margin="0,0,0,12">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding Name}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" TextTrimming="CharacterEllipsis" />
                                                                <TextBlock Text="{Binding ReasonsText}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,3,0,0" />
                                                                <TextBlock Text="{Binding Category}" Style="{StaticResource SmallLabel}" Margin="0,3,0,0" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Column="1" Margin="10,0,0,0" HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding ScoreText}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" />
                                                                <TextBlock Text="{Binding Size}" Style="{StaticResource SmallLabel}" HorizontalAlignment="Right" Margin="0,3,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                    </StackPanel>

                                    <StackPanel Visibility="Collapsed">
                                    <TextBlock Text="Vault Analyze &amp; Fix" Foreground="{StaticResource NeonInk.SuccessBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <Border Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource NeonInk.SuccessBrush}" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,0,0,12">
                                        <StackPanel>
                                            <TextBlock Text="{Binding VaultHealthSummary}" Style="{StaticResource DataCell}" Foreground="{StaticResource PrimaryTextBrush}" Margin="0,0,0,4" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding VaultHealthBreakdown}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding VaultMaintenanceStatus}" Style="{StaticResource SmallLabel}" Margin="0,0,0,3" />
                                            <TextBlock Text="{Binding VaultMaintenanceDetail}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" />
                                            <ProgressBar Height="6"
                                                         Minimum="0"
                                                         Maximum="100"
                                                         Value="{Binding VaultMaintenanceProgress, Mode=OneWay}"
                                                         Margin="0,8,0,0" />
                                            <WrapPanel Margin="0,12,0,0">
                                                <Button Content="Analyze Health" Command="{Binding RepairCatalogCommand}" ToolTip="Check catalog paths, retained files, hashes, thumbnails, extracted text, and duplicate hashes without changing files." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,6" />
                                                <Button Content="Select Safe Repairs" Command="{Binding SelectSafeRepairCandidatesCommand}" ToolTip="Select repairs that only update catalog paths or regenerate generated assets." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,6" />
                                                <Button Content="Clear Selection" Command="{Binding ClearRepairSelectionCommand}" ToolTip="Clear selected repair candidates." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,6" />
                                                <Button Content="Apply Selected Repairs" Click="ApplyRepairCandidatesButton_Click" ToolTip="Apply the selected repairable candidates after confirmation." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,6" />
                                                <Button Content="Rescan Orphan Files" Command="{Binding RescanVaultCommand}" ToolTip="Find retained files that are in the vault but missing from the catalog, then adopt recoverable orphans." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,6" />
                                            </WrapPanel>
                                            <TextBlock Text="{Binding SelectedRepairSummary}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="6" Padding="8" Margin="0,0,0,12">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Vault State" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                                            <Grid Grid.Row="1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="64" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <TextBlock Text="Vault" Style="{StaticResource SmallLabel}" />
                                                <TextBlock Grid.Column="1" Text="{Binding VaultRootPath}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding VaultRootPath}" />
                                                <TextBlock Grid.Row="1" Text="Catalog" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CatalogPath}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding CatalogPath}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="2" Text="Backup" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastBackupDisplay}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" ToolTip="{Binding LastBackupDisplay}" Margin="0,7,0,0" />
                                            </Grid>
                                            <Button Grid.Row="2" Content="Backup Catalog" Command="{Binding BackupCatalogCommand}" Style="{StaticResource ToolButton}" Height="30" HorizontalAlignment="Left" Margin="0,10,0,0" />
                                        </Grid>
                                    </Border>

                                    <TextBlock Text="Findings" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                                    <ScrollViewer MaxHeight="230" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                                        <DataGrid ItemsSource="{Binding VaultHealthFindings}" MinWidth="760" IsReadOnly="True" AutoGenerateColumns="False" CanUserAddRows="False">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="70" />
                                                <DataGridTextColumn Header="Type" Binding="{Binding FindingType}" Width="140" />
                                                <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="170" />
                                                <DataGridTextColumn Header="Detail" Binding="{Binding Detail}" Width="230" />
                                                <DataGridTextColumn Header="Proposed Action" Binding="{Binding ProposedAction}" Width="260" />
                                                <DataGridCheckBoxColumn Header="Catalog" Binding="{Binding MutatesCatalog}" Width="70" />
                                                <DataGridCheckBoxColumn Header="Files" Binding="{Binding TouchesRetainedFiles}" Width="60" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>

                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="8" />
                                            <ColumnDefinition Width="120" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Repair Candidates" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1" ItemsSource="{Binding FindingTypeFilterOptions}" SelectedItem="{Binding FindingTypeFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorComboBox}" Height="30" />
                                        <ComboBox Grid.Column="3" ItemsSource="{Binding RepairCandidateFilterOptions}" SelectedItem="{Binding RepairCandidateFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorComboBox}" Height="30" />
                                    </Grid>
                                    <ScrollViewer MaxHeight="260" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" Margin="0,0,0,12">
                                        <DataGrid ItemsSource="{Binding FilteredRepairCandidates}" MinWidth="840" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="False">
                                            <DataGrid.Columns>
                                                <DataGridTemplateColumn Header="Apply" Width="58">
                                                    <DataGridTemplateColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding CanRepairAutomatically}" HorizontalAlignment="Center" />
                                                        </DataTemplate>
                                                    </DataGridTemplateColumn.CellTemplate>
                                                </DataGridTemplateColumn>
                                                <DataGridTextColumn Header="Action" Binding="{Binding ActionType}" Width="130" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Type" Binding="{Binding FindingType}" Width="140" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="160" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Proposed Action" Binding="{Binding ProposedAction}" Width="260" IsReadOnly="True" />
                                                <DataGridTextColumn Header="Selection / Result" Binding="{Binding SelectionState}" Width="150" IsReadOnly="True" />
                                                <DataGridCheckBoxColumn Header="Catalog" Binding="{Binding MutatesCatalog, Mode=OneWay}" Width="70" IsReadOnly="True" />
                                                <DataGridCheckBoxColumn Header="Files" Binding="{Binding TouchesRetainedFiles, Mode=OneWay}" Width="60" IsReadOnly="True" />
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </ScrollViewer>

                                    <TextBlock Text="Repair History" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding RepairHistory}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,0,0,9">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="70" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Result}" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                    <StackPanel Grid.Column="1" Margin="8,0,8,0">
                                                        <TextBlock Text="{Binding Subject}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                        <TextBlock Text="{Binding Detail}" Style="{StaticResource SmallLabel}" FontSize="11" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                        <TextBlock Text="{Binding ActionType}" Style="{StaticResource SmallLabel}" FontSize="11" HorizontalAlignment="Right" />
                                                        <TextBlock Text="{Binding Timestamp}" Style="{StaticResource SmallLabel}" FontSize="11" HorizontalAlignment="Right" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    </StackPanel>

                                    <StackPanel Visibility="{Binding IsDetailsTabSelected, Converter={StaticResource BoolToVisibility}}">
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EditName}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.StarText}" Foreground="{StaticResource NeonInk.ImportantBrush}" FontSize="17" Margin="8,0,0,0" />
                                    </Grid>
                                    <TextBlock Text="{Binding SelectedArtifact.SummaryText}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" Margin="0,0,0,22" />

                                    <TextBlock Text="Editable Metadata" Foreground="{StaticResource NeonInk.FeaturedBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <TextBox Text="{Binding EditName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" />
                                    <ComboBox Text="{Binding EditCategory, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding CategoryNames}"
                                              IsEditable="True"
                                              Style="{StaticResource EditorComboBox}"
                                              Margin="0,0,0,8" />
                                    <TextBox Text="{Binding EditTagsText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Comma-separated tags" />
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="62" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Rating" Style="{StaticResource SmallLabel}" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="5" TickFrequency="1" IsSnapToTickEnabled="True" Value="{Binding EditRating, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>

                                    <TextBlock Text="Operator Context" Foreground="{StaticResource NeonInk.ProcessBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <TextBlock Text="Retention reason" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditRetentionReason, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Retention reason" />
                                    <TextBlock Text="Why this matters" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditWhyThisMatters, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Why this matters" />
                                    <TextBlock Text="Source provenance" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditSourceProvenance, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Source or provenance" />
                                    <TextBlock Text="Acquisition method" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <TextBox Text="{Binding EditAcquisitionMethod, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource EditorTextBox}" Margin="0,0,0,8" ToolTip="Acquisition method" />
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Trust" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="Priority" Style="{StaticResource SmallLabel}" Margin="8,0,0,0" />
                                    </Grid>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <ComboBox SelectedItem="{Binding EditTrustClassification, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding TrustClassificationOptions}"
                                                  Style="{StaticResource EditorComboBox}"
                                                  Margin="0,0,4,0"
                                                  ToolTip="Trust classification" />
                                        <ComboBox Grid.Column="1"
                                                  SelectedItem="{Binding EditRetentionPriority, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{Binding RetentionPriorityOptions}"
                                                  Style="{StaticResource EditorComboBox}"
                                                  Margin="4,0,0,0"
                                                  ToolTip="Retention priority" />
                                    </Grid>
                                    <TextBlock Text="Archive status" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    <ComboBox SelectedItem="{Binding EditArchiveStatus, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding ArchiveStatusOptions}"
                                              Style="{StaticResource EditorComboBox}"
                                              Margin="0,0,0,18"
                                              ToolTip="Archive status" />

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Path" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Path}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Type" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Type}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Created" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Created}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Modified" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.DateModified}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <TextBlock Text="Integrity Hashes" Foreground="{StaticResource NeonInk.VerifiedBrush}" FontSize="11" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding SelectedHashDisplays}" Margin="0,0,0,14">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="{Binding AccentBackground}" BorderBrush="{Binding AccentBrush}" BorderThickness="1" CornerRadius="5" Padding="8,6" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <Grid Margin="0,0,0,4">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="{Binding AccentBrush}" FontSize="11" />
                                                        </Grid>
                                                        <TextBlock Text="{Binding Value}" Style="{StaticResource DataCell}" FontSize="11" TextWrapping="Wrap" TextTrimming="CharacterEllipsis" />
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="File" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding StoredFileStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Hash" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.HashStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Text" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.ExtractedTextStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Preview" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.ThumbnailStatus}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Index" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.ExtractedTextRelativePath}" Style="{StaticResource DataCell}" FontSize="12" TextWrapping="Wrap" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Original" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.OriginalPath}" Style="{StaticResource DataCell}" FontSize="12" TextWrapping="Wrap" />
                                    </Grid>

                                    <TextBlock Text="Tags" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                    <ItemsControl ItemsSource="{Binding SelectedArtifact.Tags}" Margin="0,0,0,14">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Style="{StaticResource Chip}">
                                                    <TextBlock Text="{Binding}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" />
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Category" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.Category}" Style="{StaticResource DataCell}" FontSize="12" />
                                    </Grid>
                                    <Grid Margin="0,0,0,18">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="62" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <TextBlock Text="Rating" Style="{StaticResource SmallLabel}" />
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedArtifact.RatingText}" Foreground="{StaticResource NeonInk.ImportantBrush}" FontSize="14" />
                                    </Grid>

                                    <TextBlock Text="Notes" Style="{StaticResource SmallLabel}" Margin="0,0,0,8" />
                                    <TextBox Text="{Binding EditNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource EditorTextBox}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="88"
                                             Margin="0,0,0,12" />
                                    <Grid Margin="0,0,0,24">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding EditStatus}" Style="{StaticResource SmallLabel}" VerticalAlignment="Center" />
                                        <Button Grid.Column="1" Content="Revert" Command="{Binding RevertArtifactCommand}" Style="{StaticResource ToolButton}" Margin="0,0,8,0" />
                                        <Button Grid.Column="2" Content="Save" Command="{Binding SaveArtifactCommand}" Style="{StaticResource ToolButton}" />
                                    </Grid>

                                    <TextBlock Text="ACTIONS" Style="{StaticResource SmallLabel}" Margin="0,0,0,14" />
                                    <UniformGrid Columns="4" Rows="2" Margin="0,0,0,8">
                                        <Button Command="{Binding OpenLocationCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE838;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Open&#x0a;Location" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding OpenFileCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE8A7;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Open&#x0a;File" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Click="RestoreArtifactButton_Click" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE8E5;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Restore&#x0a;Copy" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding ToggleStarCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE735;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Toggle&#x0a;Star" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding AddTagsCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE8EC;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Add&#x0a;Tags" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding HashCheckCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE72E;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Hash&#x0a;Check" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Command="{Binding QuarantineCommand}" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" HorizontalAlignment="Center" /><TextBlock Text="Quaran-&#x0a;tine" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                        <Button Click="DeleteArtifactButton_Click" Style="{StaticResource ToolButton}" Height="54" Padding="0">
                                            <StackPanel><TextBlock Text="&#xE74D;" Style="{StaticResource IconText}" HorizontalAlignment="Center" Foreground="{StaticResource NeonInk.CriticalBrush}" /><TextBlock Text="Delete&#x0a;Forever" Style="{StaticResource SmallLabel}" TextAlignment="Center" /></StackPanel>
                                        </Button>
                                    </UniformGrid>
                                    <TextBlock Text="{Binding ActionStatus}" Style="{StaticResource SmallLabel}" Margin="0,0,0,4" />
                                    </StackPanel>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Margin="0,10,0,0" Visibility="Collapsed">
                            <Grid Margin="14,12">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="VAULT HEALTH" Foreground="{StaticResource NeonInk.SuccessBrush}" FontSize="12" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding VaultHealthSummary}" Style="{StaticResource SmallLabel}" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding VaultMaintenanceStatus}" Style="{StaticResource SmallLabel}" Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding VaultMaintenanceDetail}" Style="{StaticResource SmallLabel}" Margin="0,3,0,0" TextTrimming="CharacterEllipsis" MaxWidth="520" />
                                        <ProgressBar Height="5"
                                                     Minimum="0"
                                                     Maximum="100"
                                                     Value="{Binding VaultMaintenanceProgress, Mode=OneWay}"
                                                     Margin="0,7,0,0" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Analyze Health" Command="{Binding RepairCatalogCommand}" ToolTip="Check vault health without changing retained files." Style="{StaticResource ToolButton}" Height="30" />
                                </Grid>

                                <Grid Grid.Row="1" Margin="0,12,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="72" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="Vault" Style="{StaticResource SmallLabel}" />
                                    <TextBlock Grid.Column="1" Text="{Binding VaultRootPath}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" />

                                    <TextBlock Grid.Row="1" Text="Catalog" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CatalogPath}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,7,0,0" />

                                    <TextBlock Grid.Row="2" Text="Intake" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding IngestModeText}" Style="{StaticResource DataCell}" FontSize="12" Margin="0,7,0,0" />

                                    <TextBlock Grid.Row="3" Text="Backup" Style="{StaticResource SmallLabel}" Margin="0,7,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastBackupDisplay}" Style="{StaticResource DataCell}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,7,0,0" />

                                    <Border Grid.Row="4" Grid.ColumnSpan="2" Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="6" Margin="0,12,0,0" Padding="8">
                                        <StackPanel>
                                            <TextBlock Text="Selected Repairs" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding SelectedRepairSummary}" Style="{StaticResource SmallLabel}" TextWrapping="Wrap" Margin="0,4,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Row="5" Grid.ColumnSpan="2" Background="{StaticResource NeonInk.BaseBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="6" Margin="0,8,0,0" Padding="8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Repair History" Foreground="{StaticResource PrimaryTextBrush}" FontSize="12" FontWeight="SemiBold" />
                                            <TextBlock Grid.Column="1" Text="{Binding RepairHistorySummary}" Style="{StaticResource SmallLabel}" FontSize="11" />
                                        </Grid>
                                    </Border>
                                </Grid>

                                <WrapPanel Grid.Row="2">
                                    <Button Content="Choose Vault" Click="ChooseVaultButton_Click" ToolTip="Select the vault folder FileCabinet should use." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="{Binding IngestModeText}" Command="{Binding ToggleIngestModeCommand}" ToolTip="Switch between moving files into the vault and copying files into the vault." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Backup Catalog" Command="{Binding BackupCatalogCommand}" ToolTip="Create and validate a catalog backup." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Analyze Health" Command="{Binding RepairCatalogCommand}" ToolTip="Check vault health without changing retained files." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Apply Selected Repairs" Click="ApplyRepairCandidatesButton_Click" ToolTip="Apply selected repairable candidates after confirmation." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,6,0" />
                                    <Button Content="Rescan Orphan Files" Command="{Binding RescanVaultCommand}" ToolTip="Find vault files that are missing from the catalog and adopt recoverable orphans." Style="{StaticResource ToolButton}" Height="30" />
                                </WrapPanel>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>
            <!-- Vault Health Modal Overlay -->
            <Grid Grid.RowSpan="2" Visibility="Collapsed" Panel.ZIndex="90">
                <Border Background="#A0000000">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding CloseVaultHealthCommand}" />
                    </Border.InputBindings>
                </Border>
                <Border Background="{StaticResource CardBgBrush}" 
                        BorderBrush="{StaticResource BorderDimBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Width="900" 
                        Height="700" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Vault Health Dashboard" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                        <Button Content="&#xE711;" 
                                Command="{Binding CloseVaultHealthCommand}" 
                                Style="{StaticResource ChromeButton}" 
                                HorizontalAlignment="Right" 
                                Margin="0,-10,-10,0" />

                        <Grid Grid.Row="1" Margin="0,20,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <TextBlock Text="Findings &amp; Issues" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                                <DataGrid ItemsSource="{Binding VaultHealthFindings}" Height="250" Margin="0,0,0,16">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Risk" Binding="{Binding RiskLevel}" Width="80" />
                                        <DataGridTextColumn Header="Type" Binding="{Binding FindingType}" Width="150" />
                                        <DataGridTextColumn Header="Subject" Binding="{Binding Subject}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>

                                <TextBlock Text="Repair Capabilities" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                                <WrapPanel Margin="0,0,0,16">
                                    <Button Content="Refresh View" Command="{Binding RefreshCommand}" ToolTip="Reload the catalog and visible vault state." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                    <Button Content="Analyze Health" Command="{Binding RepairCatalogCommand}" ToolTip="Check catalog paths, retained files, hashes, thumbnails, extracted text, and duplicate hashes without changing files." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                    <Button Content="Rescan Orphan Files" Command="{Binding RescanVaultCommand}" ToolTip="Find retained files that are in the vault but missing from the catalog, then adopt recoverable orphans." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                    <Button Content="Apply Selected Repairs" Command="{Binding ApplySelectedRepairCandidatesCommand}" ToolTip="Apply selected repairable candidates." Style="{StaticResource ToolButton}" Height="30" Margin="0,0,8,8" />
                                </WrapPanel>
                            </StackPanel>

                            <Border Grid.Column="1" Background="{StaticResource PanelBgBrush}" BorderBrush="{StaticResource BorderDimBrush}" BorderThickness="1" CornerRadius="6" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Status" Style="{StaticResource SectionTitle}" Margin="0,0,0,12" />
                                    <TextBlock Text="Maintenance Running:" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding IsVaultMaintenanceRunning}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,16" />
                                    
                                    <TextBlock Text="Current Task:" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,4" />
                                    <TextBlock Text="{Binding VaultMaintenanceStatus}" Foreground="{StaticResource PrimaryTextBrush}" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,8" />
                                    <TextBlock Text="{Binding VaultMaintenanceDetail}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16" />
                                    <ProgressBar Height="6"
                                                 Minimum="0"
                                                 Maximum="100"
                                                 Value="{Binding VaultMaintenanceProgress, Mode=OneWay}" />
                                </StackPanel>
                            </Border>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                            <Button Content="Done" Command="{Binding CloseVaultHealthCommand}" Style="{StaticResource ToolButton}" Width="80" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Settings Modal Overlay -->
            <Grid Grid.RowSpan="2" Visibility="{Binding IsSettingsVisible, Converter={StaticResource BoolToVisibility}}" Panel.ZIndex="100">
                <Border Background="#A0000000">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick" Command="{Binding CloseSettingsCommand}" />
                    </Border.InputBindings>
                </Border>
                <Border Background="{StaticResource CardBgBrush}" 
                        BorderBrush="{StaticResource BorderDimBrush}" 
                        BorderThickness="1" 
                        CornerRadius="8" 
                        Width="450" 
                        Height="400" 
                        HorizontalAlignment="Center" 
                        VerticalAlignment="Center">
                    <Grid Margin="24">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource PrimaryTextBrush}" />
                        <Button Content="&#xE711;" 
                                Command="{Binding CloseSettingsCommand}" 
                                Style="{StaticResource ChromeButton}" 
                                HorizontalAlignment="Right" 
                                Margin="0,-10,-10,0" />

                        <StackPanel Grid.Row="1" Margin="0,20,0,0">
                            <TextBlock Text="Active Hashes" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                            <ScrollViewer Height="118" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                                <ItemsControl ItemsSource="{Binding HashSettingOptions}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Content="{Binding DisplayName}"
                                                      IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      Command="{Binding ToggleCommand}"
                                                      CommandParameter="{Binding}"
                                                      ToolTip="{Binding Note}"
                                                      Foreground="{StaticResource PrimaryTextBrush}"
                                                      Margin="0,0,10,5" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                            <TextBlock Text="{Binding ActiveHashSummary}" Foreground="{StaticResource SecondaryTextBrush}" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,8" />
                            <TextBlock Text="{Binding HashSettingsNote}" Foreground="{StaticResource AccentBrush}" FontSize="11" TextWrapping="Wrap" Margin="0,0,0,16" />

                            <TextBlock Text="Ingest Mode" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                            <Button Content="{Binding IngestModeText}" 
                                    Command="{Binding ToggleIngestModeCommand}" 
                                    Style="{StaticResource ToolButton}" 
                                    HorizontalAlignment="Left" 
                                    Margin="0,0,0,16" />

                            <TextBlock Text="Display Density" Style="{StaticResource SectionTitle}" Margin="0,0,0,8" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Toggle Density" Command="{Binding ToggleDensityCommand}" Style="{StaticResource ToolButton}" />
                                <TextBlock Text="{Binding DensityText}" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="{StaticResource SecondaryTextBrush}" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Content="Done" Command="{Binding CloseSettingsCommand}" Style="{StaticResource ToolButton}" Width="80" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
