<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="Atl.Color.Abyss">#050913</Color>
    <Color x:Key="Atl.Color.DeepNavy">#0B1728</Color>
    <Color x:Key="Atl.Color.Navy">#172536</Color>
    <Color x:Key="Atl.Color.Slate">#262F39</Color>
    <Color x:Key="Atl.Color.Steel">#40423F</Color>
    <Color x:Key="Atl.Color.SteelBlue">#192E46</Color>
    <Color x:Key="Atl.Color.OceanBlue">#29384A</Color>
    <Color x:Key="Atl.Color.Dusk">#36485A</Color>
    <Color x:Key="Atl.Color.BlueGrey">#53606A</Color>
    <Color x:Key="Atl.Color.CoolGrey">#6F7E87</Color>
    <Color x:Key="Atl.Color.MistBlue">#627786</Color>
    <Color x:Key="Atl.Color.MistGrey">#768892</Color>
    <Color x:Key="Atl.Color.PaleMist">#98A2A2</Color>
    <Color x:Key="Atl.Color.SeaFoam">#B9C9C5</Color>
    <Color x:Key="Atl.Color.OffWhite">#E1E7DB</Color>
    <Color x:Key="Atl.Color.ElectricCyan">#00D8FF</Color>
    <Color x:Key="Atl.Color.ArcticCyan">#65F2FF</Color>
    <Color x:Key="Atl.Color.Teal">#21C6B8</Color>
    <Color x:Key="Atl.Color.AquaTeal">#3AD1C3</Color>
    <Color x:Key="Atl.Color.Amber">#FF884D</Color>
    <Color x:Key="Atl.Color.Brass">#D9A441</Color>
    <Color x:Key="Atl.Color.Violet">#9C7CFF</Color>
    <Color x:Key="Atl.Color.Indigo">#6A5BFF</Color>
    <Color x:Key="Atl.Color.Success">#30D58C</Color>
    <Color x:Key="Atl.Color.Verified">#6FE3A4</Color>
    <Color x:Key="Atl.Color.Danger">#FF5C77</Color>
    <Color x:Key="Atl.Color.DangerDim">#3B1720</Color>
    <Color x:Key="Atl.Color.Build">#FF884D</Color>
    <Color x:Key="Atl.Color.BuildDim">#3A2712</Color>
    <Color x:Key="Atl.Color.PanelDim">#101A2A</Color>
    <Color x:Key="Atl.Color.PanelBlueDim">#123044</Color>
    <Color x:Key="Atl.Color.SuccessDim">#123522</Color>
    <Color x:Key="Atl.Color.TealDim">#12343A</Color>
    <Color x:Key="Atl.Color.TaxonomyDim">#2A214D</Color>
    <Color x:Key="Atl.Color.ArchiveDim">#1F264B</Color>

    <SolidColorBrush x:Key="Atl.Brush.Background" Color="{StaticResource Atl.Color.Abyss}" />
    <SolidColorBrush x:Key="Atl.Brush.BackgroundSoft" Color="{StaticResource Atl.Color.DeepNavy}" />
    <SolidColorBrush x:Key="Atl.Brush.Panel" Color="{StaticResource Atl.Color.Navy}" />
    <SolidColorBrush x:Key="Atl.Brush.PanelRaised" Color="{StaticResource Atl.Color.Slate}" />
    <SolidColorBrush x:Key="Atl.Brush.PanelBlue" Color="{StaticResource Atl.Color.SteelBlue}" />
    <SolidColorBrush x:Key="Atl.Brush.PanelDim" Color="{StaticResource Atl.Color.PanelDim}" />
    <SolidColorBrush x:Key="Atl.Brush.Border" Color="{StaticResource Atl.Color.Dusk}" />
    <SolidColorBrush x:Key="Atl.Brush.BorderSoft" Color="{StaticResource Atl.Color.BlueGrey}" />
    <SolidColorBrush x:Key="Atl.Brush.Text" Color="{StaticResource Atl.Color.OffWhite}" />
    <SolidColorBrush x:Key="Atl.Brush.TextSoft" Color="{StaticResource Atl.Color.SeaFoam}" />
    <SolidColorBrush x:Key="Atl.Brush.TextMuted" Color="{StaticResource Atl.Color.PaleMist}" />
    <SolidColorBrush x:Key="Atl.Brush.TextFaint" Color="{StaticResource Atl.Color.MistGrey}" />
    <SolidColorBrush x:Key="Atl.Brush.TextInverse" Color="{StaticResource Atl.Color.Abyss}" />
    <SolidColorBrush x:Key="Atl.Brush.Link" Color="{StaticResource Atl.Color.ArcticCyan}" />
    <SolidColorBrush x:Key="Atl.Brush.Action" Color="{StaticResource Atl.Color.ElectricCyan}" />
    <SolidColorBrush x:Key="Atl.Brush.ActionSoft" Color="{StaticResource Atl.Color.Teal}" />
    <SolidColorBrush x:Key="Atl.Brush.Focus" Color="{StaticResource Atl.Color.ArcticCyan}" />
    <SolidColorBrush x:Key="Atl.Brush.Warning" Color="{StaticResource Atl.Color.Amber}" />
    <SolidColorBrush x:Key="Atl.Brush.Attention" Color="{StaticResource Atl.Color.Brass}" />
    <SolidColorBrush x:Key="Atl.Brush.Taxonomy" Color="{StaticResource Atl.Color.Violet}" />
    <SolidColorBrush x:Key="Atl.Brush.Archive" Color="{StaticResource Atl.Color.Indigo}" />
    <SolidColorBrush x:Key="Atl.Brush.Success" Color="{StaticResource Atl.Color.Success}" />
    <SolidColorBrush x:Key="Atl.Brush.Verified" Color="{StaticResource Atl.Color.Verified}" />
    <SolidColorBrush x:Key="Atl.Brush.Danger" Color="{StaticResource Atl.Color.Danger}" />
    <SolidColorBrush x:Key="Atl.Brush.DangerDim" Color="{StaticResource Atl.Color.DangerDim}" />
    <SolidColorBrush x:Key="Atl.Brush.Build" Color="{StaticResource Atl.Color.Build}" />
    <SolidColorBrush x:Key="Atl.Brush.BuildDim" Color="{StaticResource Atl.Color.BuildDim}" />

    <DrawingBrush x:Key="Atl.Brush.GridBackground"
                  TileMode="Tile"
                  Viewport="0,0,32,32"
                  ViewportUnits="Absolute">
        <DrawingBrush.Drawing>
            <DrawingGroup>
                <GeometryDrawing Brush="{StaticResource Atl.Brush.Background}">
                    <GeometryDrawing.Geometry>
                        <RectangleGeometry Rect="0,0,32,32" />
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
                <GeometryDrawing>
                    <GeometryDrawing.Pen>
                        <Pen Brush="#2636485A" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0" EndPoint="32,0" />
                            <LineGeometry StartPoint="0,0" EndPoint="0,32" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingGroup>
        </DrawingBrush.Drawing>
    </DrawingBrush>

    <SolidColorBrush x:Key="WindowBgBrush" Color="{StaticResource Atl.Color.Abyss}" />
    <SolidColorBrush x:Key="PanelBgBrush" Color="{StaticResource Atl.Color.Navy}" />
    <SolidColorBrush x:Key="CardBgBrush" Color="{StaticResource Atl.Color.Navy}" />
    <SolidColorBrush x:Key="CardAltBrush" Color="{StaticResource Atl.Color.PanelDim}" />
    <SolidColorBrush x:Key="BorderDimBrush" Color="{StaticResource Atl.Color.Dusk}" />
    <SolidColorBrush x:Key="BorderGlowBrush" Color="{StaticResource Atl.Color.ElectricCyan}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource Atl.Color.ElectricCyan}" />
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="{StaticResource Atl.Color.OffWhite}" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="{StaticResource Atl.Color.SeaFoam}" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="{StaticResource Atl.Color.PaleMist}" />
    <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource Atl.Color.Success}" />

    <LinearGradientBrush x:Key="ShellGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="{StaticResource Atl.Color.Abyss}" Offset="0" />
        <GradientStop Color="{StaticResource Atl.Color.DeepNavy}" Offset="0.55" />
        <GradientStop Color="{StaticResource Atl.Color.SteelBlue}" Offset="1" />
    </LinearGradientBrush>

    <DropShadowEffect x:Key="Atl.Effect.FocusGlow" Color="{StaticResource Atl.Color.ArcticCyan}" BlurRadius="14" ShadowDepth="0" Opacity="0.22" />
    <DropShadowEffect x:Key="Atl.Effect.SuccessGlow" Color="{StaticResource Atl.Color.Verified}" BlurRadius="14" ShadowDepth="0" Opacity="0.18" />
    <DropShadowEffect x:Key="Atl.Effect.WarningGlow" Color="{StaticResource Atl.Color.Brass}" BlurRadius="12" ShadowDepth="0" Opacity="0.18" />
    <DropShadowEffect x:Key="Atl.Effect.DangerGlow" Color="{StaticResource Atl.Color.Danger}" BlurRadius="16" ShadowDepth="0" Opacity="0.2" />

    <FontFamily x:Key="Atl.Font.Sans">Aptos, Segoe UI Variable Text, Segoe UI</FontFamily>
    <FontFamily x:Key="Atl.Font.Display">Aptos Display, Segoe UI Variable Display, Segoe UI</FontFamily>
    <FontFamily x:Key="Atl.Font.Mono">Cascadia Code, Cascadia Mono, Consolas</FontFamily>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
        <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelDim}" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="10,5" />
    </Style>

    <Style TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.Text}" />
        <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelDim}" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="CaretBrush" Value="{StaticResource Atl.Brush.Focus}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Atl.Brush.ActionSoft}" />
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.Text}" />
        <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelDim}" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
    </Style>

    <Style TargetType="RadioButton">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
    </Style>

    <Style TargetType="ListBox">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
    </Style>

    <Style TargetType="DataGrid">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Background" Value="{StaticResource Atl.Brush.BackgroundSoft}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="GridLinesVisibility" Value="Horizontal" />
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="VerticalGridLinesBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="RowBackground" Value="{StaticResource Atl.Brush.BackgroundSoft}" />
        <Setter Property="AlternatingRowBackground" Value="{StaticResource Atl.Brush.PanelDim}" />
        <Setter Property="HeadersVisibility" Value="Column" />
    </Style>

    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelBlue}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.Text}" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Padding" Value="8,6" />
    </Style>

    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="{StaticResource Atl.Brush.BackgroundSoft}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelRaised}" />
            </Trigger>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelBlue}" />
                <Setter Property="Foreground" Value="{StaticResource Atl.Brush.Text}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style TargetType="TabControl">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
    </Style>

    <Style TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.Success}" />
        <Setter Property="Background" Value="{StaticResource Atl.Brush.PanelRaised}" />
        <Setter Property="BorderBrush" Value="{StaticResource Atl.Brush.Border}" />
        <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style TargetType="Menu">
        <Setter Property="FontFamily" Value="{StaticResource Atl.Font.Sans}" />
        <Setter Property="Background" Value="{StaticResource Atl.Brush.BackgroundSoft}" />
        <Setter Property="Foreground" Value="{StaticResource Atl.Brush.TextSoft}" />
    </Style>
</ResourceDictionary>
